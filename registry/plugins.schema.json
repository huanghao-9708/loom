{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://loom.app/registry/plugins.schema.json",
  "title": "Loom Plugins Registry Index",
  "description": "Loom 在线插件市场的总索引文件 (plugins.json) 的 JSON Schema。用于 Registry 仓库 CI 校验上架 PR 的合法性。",
  "type": "object",
  "required": ["registryVersion", "updatedAt", "plugins"],
  "properties": {
    "registryVersion": {
      "type": "integer",
      "description": "Registry 索引格式版本号，客户端据此判断兼容性",
      "minimum": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "索引最后更新时间 (ISO 8601)"
    },
    "plugins": {
      "type": "array",
      "items": { "$ref": "#/definitions/registryEntry" }
    }
  },
  "definitions": {
    "registryEntry": {
      "type": "object",
      "description": "市场中的一个插件条目",
      "required": ["id", "name", "version", "downloadUrl", "sha256", "minAppVersion"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(\\.[a-z0-9]+)+$",
          "description": "插件唯一标识，必须为反向域名格式，如 com.loom.music"
        },
        "name": { "type": "string", "minLength": 1, "maxLength": 64 },
        "description": { "type": "string", "maxLength": 280 },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "语义化版本号 MAJOR.MINOR.PATCH"
        },
        "iconUrl": {
          "type": "string",
          "format": "uri",
          "description": "插件图标 URL（建议 raw.githubusercontent.com 或 CDN）"
        },
        "author": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 8
        },
        "downloadUrl": {
          "type": "string",
          "format": "uri",
          "description": ".loom 包下载地址，必须为 HTTPS。建议 GitHub Releases Assets 以获得全球 CDN 加速"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$",
          "description": "下载包的 SHA-256 校验和（64 位十六进制）。客户端下载后强制校验，不符则拒绝安装"
        },
        "minAppVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "运行该插件所需的最低 Loom 宿主版本"
        },
        "homepage": { "type": "string", "format": "uri" },
        "permissions": {
          "type": "object",
          "description": "插件声明的权限（用于安装前向用户展示）",
          "properties": {
            "vfs": { "type": "array", "items": { "type": "string" } },
            "db": { "type": "boolean" },
            "net": { "type": "array", "items": { "type": "string" } },
            "ui": { "type": "array", "items": { "type": "string" } }
          }
        }
      },
      "additionalProperties": false
    }
  }
}
